						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Парк отдыха\",\n  \"description\": \"Прогулка в парке\",\n  \"order\": 4,\n  \"latitude\": 55.751244,\n  \"longitude\": 37.618423\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/trips/2/stops/",
							"host": ["{{base_url}}"],
							"path": ["api", "trips", "2", "stops", ""]
						},
						"description": "Добавить остановку к активной поездке."
					},
					"response": []
				},
				{
					"name": "Добавить остановку — ошибка (завершённая поездка)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Token {{token_vasilii}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Новая остановка\",\n  \"order\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/trips/2/stops/",
							"host": ["{{base_url}}"],
							"path": ["api", "trips", "2", "stops", ""]
						},
						"description": "Ошибка 400: нельзя добавить остановку к завершённой поездке. Сначала выполните 'complete' для поездки 2."
					},
					"response": []
				},
				{
					"name": "Детали остановки",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/trips/2/stops/1/",
							"host": ["{{base_url}}"],
							"path": ["api", "trips", "2", "stops", "1", ""]
						},
						"description": "Получить детали одной остановки."
					},
					"response": []
				},
				{
					"name": "Обновить остановку",
					"request": {
						"method": "PATCH",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Token {{token_vasilii}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"description\": \"Долгая остановка на заправке — 30 минут\",\n  \"latitude\": 55.800,\n  \"longitude\": 37.650\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/trips/2/stops/1/",
							"host": ["{{base_url}}"],
							"path": ["api", "trips", "2", "stops", "1", ""]
						},
						"description": "Обновить данные остановки. Только для владельца поездки."
					},
					"response": []
				},
				{
					"name": "Удалить остановку",
					"request": {
						"method": "DELETE",
						"header": [
							{"key": "Authorization", "value": "Token {{token_vasilii}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/trips/2/stops/3/",
							"host": ["{{base_url}}"],
							"path": ["api", "trips", "2", "stops", "3", ""]
						},
						"description": "Удалить остановку. Вернёт 204 No Content."
					},
					"response": []
				}
			]
		}
	]
